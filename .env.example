# Database (SQLite default for local dev)
DATABASE_URL=sqlite:///./simplifai.db

# Import
IMPORT_AMOUNT_TOLERANCE=0.00
DEFAULT_CURRENCY=ILS

# CORS — comma-separated origins; Vercel previews match CORS_ORIGIN_REGEX
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# AI (optional — rule-based parser works without a key)
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
