# Database — leave unset to use simplifai.db at the project root (recommended).
# Relative paths like sqlite:///./simplifai.db resolve from the process cwd and are easy to misconfigure.
# DATABASE_URL=sqlite:///C:/path/to/SimplifAI/simplifai.db

# Import
IMPORT_AMOUNT_TOLERANCE=0.00
DEFAULT_CURRENCY=ILS

# CORS — comma-separated origins; Vercel previews match CORS_ORIGIN_REGEX
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# AI (optional — rule-based parser works without a key)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# Feedback form → your inbox (SMTP; Gmail: use an App Password)
FEEDBACK_TO_EMAIL=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=you@example.com
SMTP_USE_TLS=true
